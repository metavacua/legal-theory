%% ── Peer-reviewed technical foundation (verified 3-0 by deep-research workflow) ──

@inproceedings{geva2021ffn,
  author       = {Geva, Mor and Schuster, Roei and Berant, Jonathan and Levy, Omer},
  title        = {Transformer Feed-Forward Layers Are Key-Value Memories},
  booktitle    = {Proceedings of the 2021 Conference on Empirical Methods in Natural Language Processing ({EMNLP} 2021)},
  year         = {2021},
  eprint       = {2012.14913},
  archivePrefix= {arXiv},
  url          = {https://arxiv.org/abs/2012.14913},
  note         = {Foundational peer-reviewed paper establishing that each FFN layer operates as a key-value memory: rows of W1 are keys that detect input patterns; rows of W2 are values that encode output distributions. Confirmed 3-0 in deep-research adversarial verification (2026-07-01).}
}

@inproceedings{geva2022transformer,
  author       = {Geva, Mor and Caciularu, Avi and Wang, Kevin and Goldberg, Yoav},
  title        = {Transformer Feed-Forward Layers Build Predictions by Promoting Concepts in the Vocabulary Space},
  booktitle    = {Proceedings of the 2022 Conference on Empirical Methods in Natural Language Processing ({EMNLP} 2022)},
  year         = {2022},
  eprint       = {2203.14680},
  archivePrefix= {arXiv},
  url          = {https://arxiv.org/abs/2203.14680},
  note         = {Operationalises the key-value framing: W\textsubscript{K} rows are keys; W\textsubscript{V} columns are values; forward-pass output is a weighted sum of stored value vectors. Confirmed 3-0 in deep-research adversarial verification (2026-07-01).}
}

%% ── EU legal authority (verified 2-1 by deep-research workflow) ──

@misc{gema_openai2025,
  author       = {{Munich Regional Court I (Landgericht M\"{u}nchen I)}},
  title        = {{GEMA} v. {OpenAI}, Case 42~O~14139/24},
  year         = {2025},
  month        = {November},
  note         = {11 November 2025. Munich Regional Court ruled that memorisation of protected musical works ``in probability values distributed across parameters'' is unlawful reproduction under German \emph{Urheberrechtsgesetz} §16 (\emph{UrhG}). First EU ruling that model weights containing memorised protected content constitute unauthorised reproduction. Confirmed 2-1 in deep-research adversarial verification (2026-07-01). Subject to appeal.}
}

@techreport{lucchi2025ep,
  author       = {Lucchi, Nicola},
  title        = {Artificial Intelligence and Intellectual Property: Mapping the Issues and Challenges},
  institution  = {European Parliament, IUST Committee},
  year         = {2025},
  number       = {PE 774.095},
  url          = {https://www.europarl.europa.eu/RegData/etudes/STUD/2025/774095/IUST_STU(2025)774095_EN.pdf},
  note         = {European Parliament institutional study. Finds it a ``strong argument'' that model weights ``may implicate'' reproduction rights and that distributing memorised-content weights constitutes prima facie infringement. Confirmed 2-1 in deep-research adversarial verification (2026-07-01).}
}

%% ── Strict product liability for AI (deep-research surfaced) ──

@misc{garcia_characterai2025,
  title        = {Garcia v. {Character Technologies} ({Character.AI})},
  year         = {2025},
  month        = {May},
  note         = {M.D. Fla. May 2025. Judge Anne C. Conway denied motion to dismiss, ruling that {Character.AI} qualifies as a ``product'' subject to strict products liability claims for design defects (including defects causing foreseeable harm). First US federal ruling that strict product liability applies to an {LLM}-based product. Relevant to hallucinations-as-product-defect argument.}
}

